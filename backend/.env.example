# backend/.env.example
# 复制为 .env 并填入真实值，此文件可安全提交到 git

# DeepSeek（启用外部 AI 分析）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# CORS（逗号分隔；本地默认 http://localhost:3000，生产填 https://your-frontend.onrender.com）
GEOSCOPE_CORS_ORIGINS=http://localhost:3000

# 轻量隔离（默认要求请求带 X-Client-Id）
GEOSCOPE_REQUIRE_CLIENT_ID=true

# 防滥用
GEOSCOPE_ANALYZE_PER_MINUTE=20
GEOSCOPE_AI_CALLS_PER_DAY=30

# 并发控制
GEOSCOPE_MAX_CONCURRENT_ANALYZE=2
GEOSCOPE_MAX_CONCURRENT_PLAYWRIGHT=1

# 安全（仅调试时打开）
GEOSCOPE_ALLOW_PRIVATE_NETWORKS=false

# 心跳（Render 部署时配置实际 URL）
GEOSCOPE_HEARTBEAT_SECONDS=300
GEOSCOPE_HEALTHCHECK_URL=http://127.0.0.1:8000/api/health
